# SprinklerFun — environment configuration
# Copy to `.env.local` and fill in. All values are server-side unless prefixed
# NEXT_PUBLIC_.

# --- Turso / libSQL -------------------------------------------------------
# The libSQL database URL. Leave BOTH of these unset for local development —
# the app falls back to a local SQLite file at ./.data/sprinkler.db (gitignored).
# For production, point at your Turso database:
#   TURSO_DATABASE_URL=libsql://<your-db>.turso.io
TURSO_DATABASE_URL=

# Auth token for the remote Turso database (not needed for file: URLs).
TURSO_AUTH_TOKEN=

# --- Timezone (IMPORTANT) -------------------------------------------------
# Enrichment converts Flume's UTC timestamps to LOCAL time so minute-of-day
# aligns with the configured sprinkler start times (see lib/analyze.ts). Rollups
# are computed server-side, so the server process MUST run in the homeowner's
# timezone or the rollups won't match what the browser computes.
#
# NOTE: use APP_TIMEZONE, not TZ. Vercel reserves the `TZ` env var, so lib/db.ts
# reads APP_TIMEZONE and assigns it to process.env.TZ at startup (Node honors a
# runtime TZ assignment). Set it in production to the property's IANA zone:
#   APP_TIMEZONE=America/Los_Angeles
# Locally you can leave it unset to use your machine's timezone.
APP_TIMEZONE=

# --- App write auth (single-user) ----------------------------------------
# Shared secret gating writes to /api/rows. Leave unset in local dev (writes are
# allowed). In production, set it AND set NEXT_PUBLIC_APP_SHARED_SECRET to the
# same value so the browser can send it during Phase 1 dual-write.
APP_SHARED_SECRET=
NEXT_PUBLIC_APP_SHARED_SECRET=
